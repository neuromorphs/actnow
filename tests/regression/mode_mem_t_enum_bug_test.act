import "core/globals.act";

// Regression test for a real actsim toolchain bug (not a bug in this
// project's code): sending a `mode_mem_t` value over a channel used to crash
// the simulator, because its enum-typed fields (op_mem_t, size_mem_t) were
// mis-sized by actsim's expr_multires (state.cc) -- it counted the field
// when sizing the channel value but didn't know how to fill it, so the
// internal `pos`/`nvals` counters disagreed and the simulator hit
// `Assertion: pos == nvals` on the first send/receive. (A bare enum sent
// directly, not nested in a struct, was always fine.)
//
// Fixed upstream in asyncvlsi/actsim commit fa1a636 ("tests and fixes for
// user-defined enums"). This test exists to catch a regression if an older
// actsim ever gets installed again.
defproc sender(chan!(mode_mem_t) c) {
    mode_mem_t m;
    chp {
        m.op := op_mem_t.W, m.size := size_mem_t.WORD;
        c!m
    }
}

defproc receiver(chan?(mode_mem_t) c) {
    mode_mem_t m;
    chp {
        c?m;
        log("received")
    }
}

defproc mode_mem_t_enum_bug_test() {
    chan(mode_mem_t) ch;
    sender s(ch);
    receiver r(ch);
}

mode_mem_t_enum_bug_test mt;
