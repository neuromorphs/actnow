import "../soc.act";

function build_r_insn(int<7> opcode; int<5> rd; int<3> funct3; int<5> rs1; int<5> rs2; int<7> funct7) : int<32>
{
    chp {
        self := (funct7 << 25) | (rs2 << 20) | (rs1 << 15) | (funct3 << 12) | (rd << 7) | opcode
    }
}

function build_i_insn(int<7> opcode; int<5> rd; int<3> funct3; int<5> rs1; int<12> imm) : int<32>
{
    chp {
        self := (imm << 20) | (rs1 << 15) | (funct3 << 12) | (rd << 7) | opcode
    }
}

defproc alu_op_test() {

    soc s;
    int<32> imem_req_recv;
    int<32> delay;
    int<32> insn;

    int<12> imm;
    int<7> opcode;
    int<5> rd;
    int<5> rs1;
    int<5> rs2;
    int<3> funct3;
    int<7> funct7;

    chp {

        delay := 200;
        *[ delay > 0 -> delay := delay - 1];

        s.event_id_1!(true);

        s.imem_req?imem_req_recv;

        s.imem_resp!(build_i_insn(0b0010011, 0b001, 0b000, 0b010, 0b000000000101)); // ADDI x1, x2, 5

        delay := 200;
        *[ delay > 0 -> delay := delay - 1];

        s.event_id_0!(true);

        s.imem_req?imem_req_recv;
        s.imem_resp!(build_r_insn(0b0110011, 0b00011, 0b000, 0b00001, 0b00010, 0b0000000)) // ADD x3, x1, x2

    }

}

alu_op_test at;