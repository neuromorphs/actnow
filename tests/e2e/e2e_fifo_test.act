import "core/soc.act";
import "core/peripherals/fifo_in.act";
import "core/peripherals/fifo_out.act";
import "gen/file_ids.act";

// End-to-end testbench modeling how this chip actually operates: bootload a
// real compiled program (software/application/main.c, built BOOT=1-style --
// see the top-level Makefile's `ROM_TEST=application` handling), let it
// configure its own interrupt vector, its input FIFO's trigger level
// (BATCH=3, see main.c), and go to sleep (WFI). Then push two separate
// 3-word batches into the input FIFO (with a delay between them, modeling
// real-world latency) -- fifo_in fires the interrupt *itself* once each
// batch is fully pushed, no manual triggering from this testbench at all.
// Each batch is processed by the program's own ISR and observed as 3
// results on a real output FIFO.
//
// Address layout once the bootloader hands off to the application (which
// runs from internal SRAM, base=0 -- see soc.act's own internal MMU routes
// for base 0/1, both handled entirely inside soc):
//   base=4 -> ROM (only used by the bootloader itself, briefly, before it
//             jumps to SRAM -- nothing after that ever touches it again)
//   base=5 -> input FIFO (fifo_in.act)
//   base=6 -> output FIFO (fifo_out.act)
// This external bus is a plain N-way address demux -- mmu.act's generic
// router reused with no catch-all (ADDR_NO_CATCHALL disables it, since
// every address out here is one of the three exact bases above).
defproc e2e_fifo_test() {
    soc s;

    pint DEMUX_N = 3;
    pint DEMUX_BASES[DEMUX_N];
    DEMUX_BASES = {4, 5, 6};
    mmu<DEMUX_N, DEMUX_BASES, ADDR_NO_CATCHALL> demux;

    demux.addr_core = s.addr_ext;
    demux.mode_core = s.mode_ext;
    demux.wdata_core = s.wdata_ext;
    demux.rdata_core = s.rdata_ext;

    mem<true, ROM_IMAGE> rom;
    demux.addr_out[0] = rom.addr;
    demux.mode_out[0] = rom.mode;
    demux.wdata_out[0] = rom.wdata;
    demux.rdata_out[0] = rom.rdata;

    fifo_in<4> fin;
    demux.addr_out[1] = fin.addr;
    demux.mode_out[1] = fin.mode;
    demux.wdata_out[1] = fin.wdata;
    demux.rdata_out[1] = fin.rdata;
    fin.event_out = s.event_id_0;

    fifo_out<4> fout;
    demux.addr_out[2] = fout.addr;
    demux.mode_out[2] = fout.mode;
    demux.wdata_out[2] = fout.wdata;
    demux.rdata_out[2] = fout.rdata;

    int<WIDTH_DATA> result;
    int<32> delay;

    chp {
        log("======== end-to-end interrupt/FIFO test start ========");

        // No boot-completion delay needed here: interrupt.act gates
        // event_id_0's delivery on an enable bit that main() only sets
        // after configuring the vector and fifo_in's trigger level (see
        // interrupt.act / main.c). And fifo_in itself won't fire event_out
        // until it's actually received BATCH pushes. So each push below
        // just blocks at fifo_in's own rendezvous until the program is
        // ready, and the interrupt fires itself once the batch lands --
        // self-managed synchronization the whole way, no guessed delay.

        // --- Batch 1: push 41, 42, 43 -- ISR computes +1 on each, expect
        // 42, 43, 44 out. The 3rd push is what triggers fifo_in's
        // event_out (BATCH=3, configured by main()) -- nothing here fires
        // an interrupt directly.
        log("--- batch 1: pushing 41, 42, 43 into the input FIFO ---");
        fin.push!int(41, WIDTH_DATA);
        fin.push!int(42, WIDTH_DATA);
        fin.push!int(43, WIDTH_DATA);

        fout.pop?result;
        assert(result = 42, "batch 1 result 1: want 42, got ", result);
        fout.pop?result;
        assert(result = 43, "batch 1 result 2: want 43, got ", result);
        fout.pop?result;
        assert(result = 44, "batch 1 result 3: want 44, got ", result);
        log("batch 1: got 42, 43, 44 back from the output FIFO");

        // Model some real-world latency between events.
        delay := 0;
        *[ delay < 3000 -> delay := delay + 1 ];

        // --- Batch 2: push 100, 200, 300, expect 101, 201, 301 out. Same
        // ISR, same vector, same trigger level -- the program never
        // reconfigures anything between events, exactly like a real
        // interrupt handler that just keeps running.
        log("--- batch 2: pushing 100, 200, 300 into the input FIFO ---");
        fin.push!int(100, WIDTH_DATA);
        fin.push!int(200, WIDTH_DATA);
        fin.push!int(300, WIDTH_DATA);

        fout.pop?result;
        assert(result = 101, "batch 2 result 1: want 101, got ", result);
        fout.pop?result;
        assert(result = 201, "batch 2 result 2: want 201, got ", result);
        fout.pop?result;
        assert(result = 301, "batch 2 result 3: want 301, got ", result);
        log("batch 2: got 101, 201, 301 back from the output FIFO");

        log("======== end-to-end interrupt/FIFO test complete ========")
    }
}

e2e_fifo_test e2e;
