import "assets/core/globals.act";
import "assets/core/mmu.act";

open actnow::core;

// Returns true iff w has no bits set above the transfer-size boundary,
// i.e. the MMU masked the higher bits to 0 as required.
function masked_ok (int<WIDTH_DATA> w; size_mem_t size) : bool {
    chp {
        [ size = size_mem_t.BYTE       -> self := (w{31..8} = 0)
        [] size = size_mem_t.HALF_WORD -> self := (w{31..16} = 0)
        [] else                        -> self := true
        ]
    }
}

// Drives both of mmu's core-facing port groups from one process (not two
// independent ones), so the data-port write below is guaranteed to happen
// before the instr-port read that must observe it.
defproc stimulus (
    chan!(addr_t) addr_data; chan!(mode_mem_t) mode_data;
    chan!(int<WIDTH_DATA>) wdata_data; chan!(int<WIDTH_DATA>) exp_data;
    chan!(addr_t) addr_instr; chan!(mode_mem_t) mode_instr;
    chan!(int<WIDTH_DATA>) exp_instr
) {
    addr_t a;
    mode_mem_t md;
    int<WIDTH_DATA> w, e;

    chp {
        log("======== MMU test start ========");

        // ---------------- Data port: RAM route (base=0) ----------------
        // ram_backend below is a small stateful model (unlike
        // intctrl_backend/ext_backend, which just echo) -- read-your-own-
        // write is the one property worth demonstrating here.

        log("--- Data: WORD write 0x11111111 to RAM offset 0 ---");
        a.base := 0; a.offset := int(0, WIDTH_ADDR_OFFSET);
        md.op := op_mem_t.W; md.size := size_mem_t.WORD;
        w := int(0x11111111, WIDTH_DATA);
        addr_data!a; mode_data!md; wdata_data!w;

        log("--- Data: WORD read RAM offset 0 -> expect 0x11111111 ---");
        a.base := 0; a.offset := int(0, WIDTH_ADDR_OFFSET);
        md.op := op_mem_t.R; md.size := size_mem_t.WORD;
        e := int(0x11111111, WIDTH_DATA);
        addr_data!a; mode_data!md; exp_data!e;

        log("--- Data: BYTE write 0xDEADBEEF to RAM offset 1 -> backend observes 0x000000EF ---");
        a.base := 0; a.offset := int(1, WIDTH_ADDR_OFFSET);
        md.op := op_mem_t.W; md.size := size_mem_t.BYTE;
        w := int(0xDEADBEEF, WIDTH_DATA);
        addr_data!a; mode_data!md; wdata_data!w;

        log("--- Data: BYTE read RAM offset 1 -> expect 0xEF ---");
        a.base := 0; a.offset := int(1, WIDTH_ADDR_OFFSET);
        md.op := op_mem_t.R; md.size := size_mem_t.BYTE;
        e := int(0xEF, WIDTH_DATA);
        addr_data!a; mode_data!md; exp_data!e;

        log("--- Data: HALF_WORD write 0xDEADBEEF to RAM offset 2 -> backend observes 0x0000BEEF ---");
        a.base := 0; a.offset := int(2, WIDTH_ADDR_OFFSET);
        md.op := op_mem_t.W; md.size := size_mem_t.HALF_WORD;
        w := int(0xDEADBEEF, WIDTH_DATA);
        addr_data!a; mode_data!md; wdata_data!w;

        log("--- Data: HALF_WORD read RAM offset 2 -> expect 0xBEEF ---");
        a.base := 0; a.offset := int(2, WIDTH_ADDR_OFFSET);
        md.op := op_mem_t.R; md.size := size_mem_t.HALF_WORD;
        e := int(0xBEEF, WIDTH_DATA);
        addr_data!a; mode_data!md; exp_data!e;

        log("--- Data: WORD RMW at fresh RAM offset 3 -> old value is ram_backend's initial 0xDEADBEEF ---");
        a.base := 0; a.offset := int(3, WIDTH_ADDR_OFFSET);
        md.op := op_mem_t.R_AND_W; md.size := size_mem_t.WORD;
        w := int(0x33333333, WIDTH_DATA);
        e := int(0xDEADBEEF, WIDTH_DATA);
        addr_data!a; mode_data!md; wdata_data!w; exp_data!e;

        // ---------------- Data port: interrupt controller (base=1) ----------------
        log("--- Data: WORD write to interrupt controller (base=1) ---");
        a.base := 1; a.offset := int(0, WIDTH_ADDR_OFFSET);
        md.op := op_mem_t.W; md.size := size_mem_t.WORD;
        w := int(0x2000, WIDTH_DATA);
        addr_data!a; mode_data!md; wdata_data!w;

        log("--- Data: WORD read from interrupt controller -> expect 0xDEADBEEF (intctrl_backend echo) ---");
        a.base := 1; a.offset := int(0, WIDTH_ADDR_OFFSET);
        md.op := op_mem_t.R; md.size := size_mem_t.WORD;
        e := int(0xDEADBEEF, WIDTH_DATA);
        addr_data!a; mode_data!md; exp_data!e;

        log("--- Data: HALF_WORD RMW to interrupt controller -> write expects 0x0000BEEF ---");
        a.base := 1; a.offset := int(0, WIDTH_ADDR_OFFSET);
        md.op := op_mem_t.R_AND_W; md.size := size_mem_t.HALF_WORD;
        w := int(0xDEADBEEF, WIDTH_DATA);
        e := int(0xBEEF, WIDTH_DATA);
        addr_data!a; mode_data!md; wdata_data!w; exp_data!e;

        // ---------------- Data port: external catch-all (base=4) ----------------
        log("--- Data: WORD RMW to external catch-all (base=4) ---");
        a.base := 4; a.offset := int(0, WIDTH_ADDR_OFFSET);
        md.op := op_mem_t.R_AND_W; md.size := size_mem_t.WORD;
        w := int(0x3000, WIDTH_DATA);
        e := int(0xDEADBEEF, WIDTH_DATA);
        addr_data!a; mode_data!md; wdata_data!w; exp_data!e;

        log("--- Data: BYTE RMW to external catch-all -> write expects 0x000000EF ---");
        a.base := 4; a.offset := int(1, WIDTH_ADDR_OFFSET);
        md.op := op_mem_t.R_AND_W; md.size := size_mem_t.BYTE;
        w := int(0xDEADBEEF, WIDTH_DATA);
        e := int(0xEF, WIDTH_DATA);
        addr_data!a; mode_data!md; wdata_data!w; exp_data!e;

        // ---------------- Data port: unreachable gap (base=2,3) ----------------
        log("--- Data: write to reserved base=2/3 (no-op, wdata still consumed) ---");
        a.base := 2; a.offset := int(0, WIDTH_ADDR_OFFSET);
        md.op := op_mem_t.W; md.size := size_mem_t.WORD;
        w := int(0x4000, WIDTH_DATA);
        addr_data!a; mode_data!md; wdata_data!w;

        a.base := 3; a.offset := int(0, WIDTH_ADDR_OFFSET);
        md.op := op_mem_t.W; md.size := size_mem_t.WORD;
        w := int(0x5000, WIDTH_DATA);
        addr_data!a; mode_data!md; wdata_data!w;

        // ---------------- Instr port ----------------
        // Cross-port test: instr reads the exact RAM offset the data port
        // wrote 0x11111111 into above -- must observe it, proving the two
        // ports genuinely share one physical resource rather than each
        // having their own private copy.
        log("--- Instr: WORD read RAM offset 0 -> must observe the data port's earlier write, 0x11111111 ---");
        a.base := 0; a.offset := int(0, WIDTH_ADDR_OFFSET);
        md.op := op_mem_t.R; md.size := size_mem_t.WORD;
        e := int(0x11111111, WIDTH_DATA);
        addr_instr!a; mode_instr!md; exp_instr!e;

        // XIP test: instr reaches the catch-all too, not just RAM -- this
        // is what lets core fetch its reset vector (and, without BOOT=1,
        // every instruction) from external ROM rather than internal RAM.
        log("--- Instr: WORD read through catch-all (base=4, external) -> expect 0xDEADBEEF (ext_backend echo) ---");
        a.base := 4; a.offset := int(0, WIDTH_ADDR_OFFSET);
        md.op := op_mem_t.R; md.size := size_mem_t.WORD;
        e := int(0xDEADBEEF, WIDTH_DATA);
        addr_instr!a; mode_instr!md; exp_instr!e;

        log("======== MMU test complete ========")
    }
}

// Sink for read data. Checks each returned value against the expected
// (post-mask) value supplied on `exp`. Reused once per mmu read port
// (data, instr) -- each has its own physically distinct rdata channel.
defproc read_sink (chan?(int<WIDTH_DATA>) rdata; chan?(int<WIDTH_DATA>) exp) {
    int<WIDTH_DATA> r, e;

    chp {
        *[ rdata?r; exp?e;
           log("%xRead data: 0x", r);
           assert(r = e, "read data mismatch: MMU read-side masking/routing broken")
        ]
    }
}

// Small stateful RAM-like backend -- unlike intctrl_backend/ext_backend
// below (stateless echo-testers), this one genuinely remembers what was
// written, which is what lets the cross-port test prove instr and data
// share one physical resource. 8 word slots indexed by the low 3 bits of
// the offset -- deliberately simpler than mem.act's real byte-lane
// addressing (already covered by tests/peripherals/mem_test.act); this only
// needs to prove "a write is visible to a later read."
defproc ram_backend (
    chan?(addr_t) addr; chan?(mode_mem_t) mode;
    chan?(int<WIDTH_DATA>) wdata; chan!(int<WIDTH_DATA>) rdata
) {
    addr_t a;
    mode_mem_t md;
    op_mem_t o;
    size_mem_t s;
    int<WIDTH_DATA> w, r;
    int<WIDTH_DATA> slot[8];
    int<3> idx;
    int i;

    chp {
        i := 0;
        *[ i < 8 -> slot[i] := int(0xDEADBEEF, WIDTH_DATA); i := i + 1 ];
        *[
            addr?a; mode?md;
            o := md.op;
            s := md.size;
            idx := a.offset{2..0};
            [
                o = op_mem_t.W ->
                    wdata?w;
                    assert(masked_ok(w, s), "RAM: write data not masked to transfer size");
                    slot[idx] := w;
                    log("%xRAM: Write 0x", w, "%u (size=", s, ") to offset=", a.offset)
                [] o = op_mem_t.R ->
                    r := slot[idx];
                    rdata!r;
                    log("%xRAM: Read 0x", r, "%u (size=", s, ") from offset=", a.offset)
                [] o = op_mem_t.R_AND_W ->
                    wdata?w;
                    assert(masked_ok(w, s), "RAM: RMW write data not masked to transfer size");
                    r := slot[idx];
                    slot[idx] := w;
                    rdata!r;
                    log("%xRAM: RMW write 0x", w, "%x read 0x", r, "%u (size=", s, ") from offset=", a.offset)
            ]
        ]
    }
}

// Interrupt controller backend (stateless echo-tester, same as demux_test.act's)
defproc intctrl_backend (
    chan?(addr_t) addr; chan?(mode_mem_t) mode;
    chan?(int<WIDTH_DATA>) wdata; chan!(int<WIDTH_DATA>) rdata
) {
    addr_t a;
    mode_mem_t md;
    op_mem_t o;
    size_mem_t s;
    int<WIDTH_DATA> w, r;

    chp {
        *[
            addr?a; mode?md;
            o := md.op;
            s := md.size;
            [
                o = op_mem_t.W ->
                    wdata?w;
                    assert(masked_ok(w, s), "INTCTRL: write data not masked to transfer size");
                    log("%xINTCTRL: Write 0x", w, "%u (size=", s, ") to offset=", a.offset)
                [] o = op_mem_t.R ->
                    r := int(0xDEADBEEF, WIDTH_DATA);
                    rdata!r;
                    log("%xINTCTRL: Read 0x", r, "%u (size=", s, ") from offset=", a.offset)
                [] o = op_mem_t.R_AND_W ->
                    wdata?w;
                    assert(masked_ok(w, s), "INTCTRL: RMW write data not masked to transfer size");
                    r := int(0xDEADBEEF, WIDTH_DATA);
                    rdata!r;
                    log("%xINTCTRL: RMW write 0x", w, "%x read 0x", r, "%u (size=", s, ") from offset=", a.offset)
            ]
        ]
    }
}

// External catch-all backend (stateless echo-tester, same as demux_test.act's)
defproc ext_backend (
    chan?(addr_t) addr; chan?(mode_mem_t) mode;
    chan?(int<WIDTH_DATA>) wdata; chan!(int<WIDTH_DATA>) rdata
) {
    addr_t a;
    mode_mem_t md;
    op_mem_t o;
    size_mem_t s;
    int<WIDTH_DATA> w, r;

    chp {
        *[
            addr?a; mode?md;
            o := md.op;
            s := md.size;
            [
                o = op_mem_t.W ->
                    wdata?w;
                    assert(masked_ok(w, s), "EXT: write data not masked to transfer size");
                    log("%xEXT: Write 0x", w, "%u (size=", s, ") to addr base=", a.base, " offset=", a.offset)
                [] o = op_mem_t.R ->
                    r := int(0xDEADBEEF, WIDTH_DATA);
                    rdata!r;
                    log("%xEXT: Read 0x", r, "%u (size=", s, ") from addr base=", a.base, " offset=", a.offset)
                [] o = op_mem_t.R_AND_W ->
                    wdata?w;
                    assert(masked_ok(w, s), "EXT: RMW write data not masked to transfer size");
                    r := int(0xDEADBEEF, WIDTH_DATA);
                    rdata!r;
                    log("%xEXT: RMW write 0x", w, "%x read 0x", r, "%u (size=", s, ") from addr base=", a.base, " offset=", a.offset)
            ]
        ]
    }
}

// Main testbench
defproc mmu_test() {
    stimulus stim;
    read_sink rsink_data;
    read_sink rsink_instr;

    // Same 2-exact+catch-all shape as core's own instantiation: internal
    // RAM=base0, interrupt controller=base1, catch-all for external
    // (base>=ADDR_EXT_MIN=4) -- see mmu.act's own comment for why bases
    // 2/3 are unreachable by construction rather than needing an explicit
    // reserved case.
    pint N_EXACT = 2;
    pint EXACT_BASES[N_EXACT];
    EXACT_BASES = {ADDR_MEM, ADDR_INT_CTRL};
    mmu<N_EXACT, EXACT_BASES, ADDR_EXT_MIN> m;

    ram_backend ram;
    intctrl_backend intctrl;
    ext_backend ext;

    // Wire the data port
    stim.addr_data = m.addr_data;
    stim.mode_data = m.mode_data;
    stim.wdata_data = m.wdata_data;
    rsink_data.rdata = m.rdata_data;
    stim.exp_data = rsink_data.exp;

    // Wire the instr port (no wdata -- there is no such channel)
    stim.addr_instr = m.addr_instr;
    stim.mode_instr = m.mode_instr;
    rsink_instr.rdata = m.rdata_instr;
    stim.exp_instr = rsink_instr.exp;

    // Wire mmu's RAM route (index 0) to the stateful ram_backend
    ram.addr = m.addr_out[0];
    ram.mode = m.mode_out[0];
    ram.wdata = m.wdata_out[0];
    m.rdata_out[0] = ram.rdata;

    // Wire mmu's interrupt controller route (index 1) to intctrl_backend
    intctrl.addr = m.addr_out[1];
    intctrl.mode = m.mode_out[1];
    intctrl.wdata = m.wdata_out[1];
    m.rdata_out[1] = intctrl.rdata;

    // Wire mmu's external route (index 2, the catch-all) to ext_backend
    ext.addr = m.addr_out[2];
    ext.mode = m.mode_out[2];
    ext.wdata = m.wdata_out[2];
    m.rdata_out[2] = ext.rdata;
}

mmu_test mt;
