import "core/regfile.act";

open actnow::core;

defproc regfile_test() {

    regfile r;
    reg_req q;
    reg_resp p;

    chp {
        // read x0 on both ports before any writes -- want 0, 0
        q.rs1_addr := 0;
        q.rs1_valid := true;
        q.rs2_addr := 0;
        q.rs2_valid := true;
        q.rd_addr := 0;
        q.rd_data := 0;
        q.rd_valid := false;
        r.req!q;
        r.resp?p;
        assert(p.rs1_data = 0, "read x0 via rs1: want 0, got ", p.rs1_data);
        assert(p.rs2_data = 0, "read x0 via rs2: want 0, got ", p.rs2_data);

        // write 42 to reg 5 (reads in this same packet are unused, rs1_valid/rs2_valid false)
        q.rs1_valid := false;
        q.rs2_valid := false;
        q.rd_addr := 5;
        q.rd_data := 42;
        q.rd_valid := true;
        r.req!q;

        // read reg5 via both ports -- want 42, 42
        q.rs1_addr := 5;
        q.rs1_valid := true;
        q.rs2_addr := 5;
        q.rs2_valid := true;
        q.rd_valid := false;
        r.req!q;
        r.resp?p;
        assert(p.rs1_data = 42, "read reg5 via rs1: want 42, got ", p.rs1_data);
        assert(p.rs2_data = 42, "read reg5 via rs2: want 42, got ", p.rs2_data);

        // attempt to write 99 to x0 -- should be silently dropped
        q.rd_addr := 0;
        q.rd_data := 99;
        q.rd_valid := true;
        r.req!q;
        r.resp?p;

        // read x0 again (want still 0) and reg5 (want still 42, unaffected)
        q.rs1_addr := 0;
        q.rs1_valid := true;
        q.rs2_addr := 5;
        q.rs2_valid := true;
        q.rd_valid := false;
        r.req!q;
        r.resp?p;
        assert(p.rs1_data = 0, "x0 after blocked write: want 0, got ", p.rs1_data);
        assert(p.rs2_data = 42, "reg5 unaffected by blocked write: want 42, got ", p.rs2_data);

        // single packet exercising a read AND a write together, mixed with one unused operand
        q.rs1_addr := 5;
        q.rs1_valid := true;    // used
        q.rs2_addr := 9;
        q.rs2_valid := false;   // unused this instruction
        q.rd_addr := 6;
        q.rd_data := 7;
        q.rd_valid := true;

        r.req!q;
        r.resp?p;
        assert(p.rs1_data = 42, "combined read+write packet, rs1: want 42, got ", p.rs1_data);

        q.rs1_addr := 6; q.rs1_valid := true;
        q.rs2_addr := 0; q.rs2_valid := false;
        q.rd_valid := false;
        r.req!q;
        r.resp?p;
        assert(p.rs1_data = 7, "read reg6 after combined packet: want 7, got ", p.rs1_data);

        log("regfile_test: all assertions passed")
    }
}

regfile_test t;
