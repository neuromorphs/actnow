import "core/soc.act";

// Drives soc through JAL followed by JALR in one continuous run. Uses a
// negative JAL offset, which exercises the immediate's sign-extension (the
// sign bit only shows up as a problem when it's actually set). JALR's
// target then depends on JAL's link register, so a wrong JALR mask or JAL
// return-address value would show up as a wrong final fetch address too.
//
// soc boots at ADDR_RESET (0x40000, base=4); everything below 0x40000 is
// outside the external region (mmu.act silently drops reads there), so a
// leading NOP advances pc to 0x40004 first, and JAL jumps back by -4 so the
// target stays inside the external region.
defproc jal_test() {

    soc s;
    addr_t addr;
    mode_mem_t mode;
    int<32> insn, off;

    chp {
        // pc=ADDR_RESET+0: NOP (FENCE) -- just advances pc so the backward
        // JAL below has room to land without underflowing the external region
        s.addr_ext?addr; s.mode_ext?mode;
        assert(addr.base = 4, "fetch 0 addr base: want 4, got ", addr.base);
        assert(addr.offset = 0, "fetch 0 addr offset: want 0, got ", addr.offset);
        s.rdata_ext!(0b0001111); // FENCE, opcode-only

        // pc=+4: JAL x1, -4 -- backward jump, opcode=1101111, rd=1
        s.addr_ext?addr; s.mode_ext?mode;
        assert(addr.offset = 4, "fetch 1 addr: want 4, got ", addr.offset);
        off := -(int(4,32));
        insn := (off{20} << 31) | (off{19..12} << 12) | (off{11} << 20) | (off{10..1} << 21) | 0b1101111 | (int(1,32) << 7);
        s.rdata_ext!insn;

        // next_pc should be 4 + (-4) = 0; rd(x1) = pc+4 = 8
        s.addr_ext?addr; s.mode_ext?mode;
        assert(addr.offset = 0, "post-JAL fetch addr: want 0, got ", addr.offset);

        // JALR x2, x1, 4 -- target = (x1=8 + 4) & ~1 = 12
        insn := (int(4,32) << 20) | (int(1,32) << 15) | (int(2,32) << 7) | 0b1100111;
        s.rdata_ext!insn;

        s.addr_ext?addr; s.mode_ext?mode;
        assert(addr.offset = 12, "post-JALR fetch addr: want 12, got ", addr.offset);
        s.rdata_ext!(11);

        log("jal_test: all assertions passed")
    }
}

jal_test t;
