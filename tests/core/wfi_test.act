import "core/soc.act";

// Drives soc through two wake/sleep cycles via event_id_1 then event_id_0.
//
// The interrupt controller's vector table is real, software-configured
// state -- there's no hardcoded address soc jumps to on a given event, so
// before the core can sleep and expect a wake-up to land somewhere sane,
// boot code stores an ISR address into the controller's per-event vector
// register (MMIO at base=ADDR_INT_CTRL, offset 4*N for event_id_N).
//
// Boot sequence fetched from ADDR_RESET:
//   LUI  x1, 0x41    -- x1 = 0x41000 (chosen ISR address for event_id_0)
//   LUI  x2, 0x42    -- x2 = 0x42000 (chosen ISR address for event_id_1)
//   LUI  x3, 0x10    -- x3 = 0x10000 (int_ctrl base, i.e. base=1 in addr_t)
//   SW   x1, 0(x3)   -- vectors[0] = 0x41000
//   SW   x2, 4(x3)   -- vectors[1] = 0x42000
//   ADDI x4, x0, 3   -- x4 = 0b11 (enable bits for event_id_0 and event_id_1)
//   SW   x4, 64(x3)  -- enable_mask = 3 -- must come after the vectors above,
//                       since interrupt.act won't even accept event_id_N
//                       until its bit here is set
//   WFI              -- go to sleep
// The SW instructions are serviced entirely inside soc -- this test only
// needs to keep answering instruction fetches on addr_ext.
defproc wfi_test() {

    soc s;
    addr_t addr;
    mode_mem_t mode;
    int<32> delay;
    int<32> insn, off;

    chp {
        // soc boots from a cold reset -- assert reset_ext once to kick it off.
        s.reset_ext!true;

        // LUI x1, 0x41
        insn := (int(0x41,32) << 12) | (int(1,32) << 7) | 0b0110111;
        s.addr_ext?addr; s.mode_ext?mode;
        assert(addr.base = 4, "boot fetch 0 addr base: want 4, got ", addr.base);
        assert(addr.offset = 0, "boot fetch 0 addr offset: want 0, got ", addr.offset);
        s.rdata_ext!insn;

        // LUI x2, 0x42
        insn := (int(0x42,32) << 12) | (int(2,32) << 7) | 0b0110111;
        s.addr_ext?addr; s.mode_ext?mode;
        assert(addr.offset = 4, "boot fetch 1 addr offset: want 4, got ", addr.offset);
        s.rdata_ext!insn;

        // LUI x3, 0x10
        insn := (int(0x10,32) << 12) | (int(3,32) << 7) | 0b0110111;
        s.addr_ext?addr; s.mode_ext?mode;
        assert(addr.offset = 8, "boot fetch 2 addr offset: want 8, got ", addr.offset);
        s.rdata_ext!insn;

        // SW x1, 0(x3)  -- vectors[0] = 0x41000
        off := int(0,32);
        insn := (off{11..5} << 25) | (int(1,32) << 20) | (int(3,32) << 15) | (0b010 << 12) | (off{4..0} << 7) | OPCODE_STORE;
        s.addr_ext?addr; s.mode_ext?mode;
        assert(addr.offset = 12, "boot fetch 3 addr offset: want 12, got ", addr.offset);
        s.rdata_ext!insn;

        // SW x2, 4(x3)  -- vectors[1] = 0x42000
        off := int(4,32);
        insn := (off{11..5} << 25) | (int(2,32) << 20) | (int(3,32) << 15) | (0b010 << 12) | (off{4..0} << 7) | OPCODE_STORE;
        s.addr_ext?addr; s.mode_ext?mode;
        assert(addr.offset = 16, "boot fetch 4 addr offset: want 16, got ", addr.offset);
        s.rdata_ext!insn;

        // ADDI x4, x0, 3  -- x4 = 0b11 (enable event_id_0 and event_id_1)
        insn := (0b000000000011 << 20) | (int(0,32) << 15) | (0b000 << 12) | (int(4,32) << 7) | OPCODE_OP_IMM;
        s.addr_ext?addr; s.mode_ext?mode;
        assert(addr.offset = 20, "boot fetch 5 addr offset: want 20, got ", addr.offset);
        s.rdata_ext!insn;

        // SW x4, 64(x3)  -- enable_mask = 3
        off := int(64,32);
        insn := (off{11..5} << 25) | (int(4,32) << 20) | (int(3,32) << 15) | (0b010 << 12) | (off{4..0} << 7) | OPCODE_STORE;
        s.addr_ext?addr; s.mode_ext?mode;
        assert(addr.offset = 24, "boot fetch 6 addr offset: want 24, got ", addr.offset);
        s.rdata_ext!insn;

        // WFI -- go to sleep
        s.addr_ext?addr; s.mode_ext?mode;
        assert(addr.offset = 28, "boot fetch 7 (WFI) addr offset: want 28, got ", addr.offset);
        s.rdata_ext!(11);

        delay := 200;
        *[ delay > 0 -> delay := delay - 1];

        s.event_id_1!(true);

        s.addr_ext?addr; s.mode_ext?mode;
        assert(addr.offset = 0x2000, "event_id_1 fetch addr offset: want 0x2000, got ", addr.offset);
        s.rdata_ext!(11);

        delay := 200;
        *[ delay > 0 -> delay := delay - 1];

        s.event_id_0!(true);

        s.addr_ext?addr; s.mode_ext?mode;
        assert(addr.offset = 0x1000, "event_id_0 fetch addr offset: want 0x1000, got ", addr.offset);
        s.rdata_ext!(11);

        log("wfi_test: all assertions passed")
    }
}

wfi_test wt;
