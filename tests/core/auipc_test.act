import "core/soc.act";

// Drives soc through a single AUIPC instruction, checking that x3 receives
// pc+imm -- not the immediate alone, and not written to the wrong register.
defproc auipc_test() {

    soc s;
    addr_t addr;
    mode_mem_t mode;
    int<32> insn;

    chp {
        // soc no longer boots itself -- assert reset_ext once to kick it off.
        s.reset_ext!true;

        // AUIPC x3, 0x1  -->  rd := pc + (1 << 12) = ADDR_RESET + 4096
        insn := (int(1,32) << 12) | (int(3,32) << 7) | 0b0010111;

        s.addr_ext?addr; s.mode_ext?mode;
        assert(addr.base = 4, "fetch addr base: want 4, got ", addr.base);
        assert(addr.offset = 0, "fetch addr offset: want 0, got ", addr.offset);
        s.rdata_ext!insn;

        s.addr_ext?addr; s.mode_ext?mode;
        s.rdata_ext!(11);

        log("auipc_test: all assertions passed")
    }
}

auipc_test t;
