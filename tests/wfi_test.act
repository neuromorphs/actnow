import "soc.act";

defproc wfi_test() {

    soc s;
    int<32> imem_req_recv;
    int<32> delay;

    chp {

        delay := 200;
        *[ delay > 0 -> delay := delay - 1];

        s.event_id_1!(true);

        s.imem_req?imem_req_recv;
        s.imem_resp!(11);

        delay := 200;
        *[ delay > 0 -> delay := delay - 1];

        s.event_id_0!(true);

        s.imem_req?imem_req_recv;
        s.imem_resp!(11)

    }

}

wfi_test wt;
