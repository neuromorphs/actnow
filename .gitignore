# fpga live-tooling scratch: regenerated by harness/host/dvs_*_live.py.
# rotate_capture_events.mem is NOT included here even though the scripts
# regenerate it too -- it's registered as a required `input` in
# tests/files/file_registry.txt, so gen/file_ids.act (a prerequisite of
# every `make test` run) fails outright if it's missing. Only the `output`
# entries in that registry are safe to leave untracked.
chips/fpga/denoise_capture_results.mem
chips/fpga/motion_capture_results.mem
chips/fpga/rotate_capture_results.mem
chips/fpga/timesurface_capture_results.mem
chips/fpga/track_capture_results.mem

.claude/*
