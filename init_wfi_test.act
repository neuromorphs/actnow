import "soc.act";

defproc init_wfi_test() {

    soc s;
    int<32> imem_req_recv;
    int<32> delay;

    chp {
        s.imem_req?imem_req_recv;
        s.imem_resp!(11);


        delay := 200000;
        *[ delay > 0 -> delay := delay - 1];

        s.event_id_3!(true);

        s.imem_req?imem_req_recv;
        s.imem_resp!(11)

    }

}

init_wfi_test iwt;
