import "chips/dvs/core.act";
import "chips/dvs/tests/e2e/spi_flash_stub.act";
import "gen/file_ids.act";

// Continuous-push variant of e2e_aer_test. That test pushes exactly BATCH into
// the AER input, then lets spi_sink verify all BATCH results before the next
// batch -- so the AER input FIFO (fifo_in) fully drains between interrupt fires.
// This one pushes a long stream as fast as fifo_in accepts it while spi_sink
// drains the results over SPI, which is what a live SciDVS does.
//
// Regression for the fifo_in single-batch hang (fixed by the watermark/re-arm
// logic in core/peripherals/fifo_in.act): before the fix the core services only
// the first batch (3 results) then deadlocks under a continuous producer. Same
// scenario as chips/bench/tests/e2e/e2e_fifo_stress_test.act and
// chips/fpga/tests/e2e/e2e_fpga_fifo_stress.act, but with the dvs chip's real
// SPI output path.

// SPI decoder that checks an arbitrary run of (addr, data) writes rather than a
// fixed table. The dvs_application ISR writes SPI_PROG_ADDR = (i%BATCH)*4 and
// SPI_PROG_DATA = value+1 per event; with inputs 1..N pushed in order, global
// word w carries addr = (w%3)*4 and data = w+2. Protocol matches e2e_aer_test's
// spi_sink exactly (R/W bit, then WIDTH_ADDR addr bits, then WIDTH_DATA data bits).
defproc spi_sink_stress(
    bool? cs; bool? sclk; bool? mosi;
    chan!(bool) done
) {
    int<WIDTH_DATA> addr_shift, data_shift, exp_addr, exp_data;
    int i, w;
    bool bit, rw;

    chp {
        w := 0;
        *[ w < 12 ->
            [cs];
            exp_addr := int((w % 3) * 4, WIDTH_DATA);
            exp_data := int(w + 2, WIDTH_DATA);

            [sclk]; rw := mosi; [~sclk];
            assert(rw, "spi_sink: expected a write (R/W bit)");

            addr_shift := 0; i := 0;
            *[ i < WIDTH_ADDR ->
                [sclk]; bit := mosi;
                addr_shift := (addr_shift << 1) | (bit ? int(1, WIDTH_DATA) : int(0, WIDTH_DATA));
                [~sclk];
                i := i + 1
            ];
            assert(addr_shift = exp_addr, "spi_sink: word ", w, " addr mismatch, want ", exp_addr, ", got ", addr_shift);

            data_shift := 0; i := 0;
            *[ i < WIDTH_DATA ->
                [sclk]; bit := mosi;
                data_shift := (data_shift << 1) | (bit ? int(1, WIDTH_DATA) : int(0, WIDTH_DATA));
                [~sclk];
                i := i + 1
            ];
            assert(data_shift = exp_data, "spi_sink: word ", w, " data mismatch, want ", exp_data, ", got ", data_shift);
            log("spi_sink: word ", w, " matched (addr=", exp_addr, ", data=", exp_data, ")");

            [~cs];
            w := w + 1
        ];
        done!true
    }
}

defproc e2e_aer_stress_test() {
    core<8> c;
    spi_flash_stub<ROM_IMAGE> flash;
    spi_sink_stress sink;
    chan(bool) sink_done;

    bool spi_boot_cs, spi_boot_sclk, spi_boot_mosi, spi_boot_miso;
    c.spi_boot_cs = spi_boot_cs; c.spi_boot_sclk = spi_boot_sclk;
    c.spi_boot_mosi = spi_boot_mosi; c.spi_boot_miso = spi_boot_miso;
    flash.cs = spi_boot_cs; flash.sclk = spi_boot_sclk;
    flash.mosi = spi_boot_mosi; flash.miso = spi_boot_miso;

    bool spi_prog_cs, spi_prog_sclk, spi_prog_mosi, spi_prog_miso;
    c.spi_prog_cs = spi_prog_cs; c.spi_prog_sclk = spi_prog_sclk;
    c.spi_prog_mosi = spi_prog_mosi; c.spi_prog_miso = spi_prog_miso;
    sink.cs = spi_prog_cs; sink.sclk = spi_prog_sclk; sink.mosi = spi_prog_mosi;
    sink.done = sink_done;

    int<32> icnt;
    bool done_recv;

    // 4 full batches (BATCH=3 in software/dvs_application).
    chp {
        log("======== dvs AER stress (continuous push) start ========");
        c.reset_ext!true;
        (
            ( icnt := 1;
              *[ icnt <= 12 ->
                    c.aer_in!int(icnt, WIDTH_AER);
                    icnt := icnt + 1
              ]
            )
            ,
            // spi_sink_stress runs concurrently, verifying each result as it
            // arrives; this blocks until it has checked all 12.
            ( sink_done?done_recv )
        );
        log("======== dvs AER stress complete: all 12 results correct ========")
    }
}

e2e_aer_stress_test east;
