import std;
import sim;

import "core/globals.act";

// Plays spi_boot's external flash role for dvs e2e tests, using a real
// compiled program image already in .mem word format -- the exact same
// file format/reader core/peripherals/rom.act uses (sim::file::openr/read),
// reused directly. spi_boot itself has no
// backing store: every CPU access becomes its own live SPI transaction
// carrying the real requested address. A real flash chip supports genuine
// random access, and so does the software running out of it -- a
// bootloader's own copy loop branches backward, so instruction fetches
// aren't monotonically increasing (confirmed by testing a lazy
// sequential-only version, which asserted on the first loop backedge) --
// so this preloads the whole file into an array up front and answers by
// address, not by file position. MAX_WORDS is a generous fixed bound
// (1024), not the real image size -- addresses beyond EOF read as 0,
// matching core/peripherals/rom.act's own zero-fill convention.
//
// A real slave, gated purely by observing cs/sclk/mosi, never
// rendezvousing with spi_boot -- same as tests/peripherals/
// spi_boot_test.act's own external_flash.
template<pint file_id>
defproc spi_flash_stub(
    bool? cs; bool? sclk; bool? mosi;
    bool! miso
) {
    pint MAX_WORDS = 1024;
    int<WIDTH_DATA> image[MAX_WORDS];
    int<WIDTH_DATA> addr_shift, data_shift;
    int i, idx;
    bool rw, bit;
    int reader_id;
    bool success;

    chp {
        idx := 0;
        *[ idx < MAX_WORDS -> image[idx] := 0; idx := idx + 1 ];

        reader_id := sim::file::openr(file_id);
        assert(reader_id != 0, "spi_flash_stub: failed to open image file");

        idx := 0;
        *[ ~sim::file::eof(reader_id) ->
            assert(idx < MAX_WORDS, "spi_flash_stub: image larger than MAX_WORDS");
            image[idx] := int(sim::file::read(reader_id), WIDTH_DATA);
            idx := idx + 1
        ];

        success := sim::file::closer(reader_id);
        assert(success, "spi_flash_stub: failed to close image file");

        miso := false;

        *[
            [cs];
            [sclk]; rw := mosi; [~sclk];
            assert(~rw, "spi_flash_stub: spi_boot should only ever read");

            addr_shift := 0; i := 0;
            *[ i < WIDTH_ADDR ->
                [sclk]; bit := mosi;
                addr_shift := (addr_shift << 1) | (bit ? int(1, WIDTH_DATA) : int(0, WIDTH_DATA));
                [~sclk];
                i := i + 1
            ];
            idx := addr_shift >> 2;
            assert(idx < MAX_WORDS, "spi_flash_stub: requested offset out of range, ", addr_shift);

            data_shift := image[idx]; i := 0;
            *[ i < WIDTH_DATA ->
                [sclk]; miso := (data_shift{31} = 1); data_shift := data_shift << 1;
                [~sclk];
                i := i + 1
            ];

            [~cs]
        ]
    }
}
