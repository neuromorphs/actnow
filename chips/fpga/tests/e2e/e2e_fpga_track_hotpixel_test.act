import "chips/fpga/soc.act";
import "core/peripherals/rom.act";
import "core/peripherals/fifo_out.act";
import "gen/file_ids.act";

// FPGA-variant test for the hot-pixel rejection of software/dvs_track/
// main.c's spatio-temporal correlation filter: replays 40 copies of one
// synthetic "stuck pixel" event (x=10, y=10, ts=0 -> packed word 169082880,
// i.e. (10<<24)|(10<<17) in the hardware ABI evt_pack.v produces) followed
// by the first 216 events of the same real recorded capture
// e2e_fpga_track_test.act uses (chips/fpga/data/dvs_capture_20260714_151049.csv)
// -- 256 events total, exactly one DUMP_INTERVAL.
//
// The correlation filter (see software/dvs_track/main.c's header) keeps an
// event only if CORR_MIN=2 of the 8 cells around it -- *excluding its own
// cell* -- were touched within the last CORR_WINDOW=30 events. The stuck
// pixel sits alone in the 4x4 cell containing (10,10) with a quiet
// neighbourhood, so every one of its 40 firings finds zero correlated
// neighbours and is dropped: excluding the cell itself is exactly what stops
// a hot pixel vouching for its own events. None reach the centroid/bbox/
// window_count, so the reported box is built purely from the real events and
// its min_x is 57, not 10 -- the stuck pixel leaves no trace. Both output
// words are asserted against the same math computed in Python when this file
// was generated.
defproc e2e_fpga_track_hotpixel_test() {
    soc<4> c;

    rom<ROM_IMAGE> rom;
    rom.addr = c.rom_addr;
    rom.mode = c.rom_mode;
    rom.rdata = c.rom_rdata;

    fifo_out<4> fout;
    fout.addr = c.io_addr;
    fout.mode = c.io_mode;
    fout.wdata = c.io_wdata;
    fout.rdata = c.io_rdata;

    int<WIDTH_DATA> result;

    chp {
        log("======== dvs track hot-pixel filter test start (fpga) ========");
        c.reset_ext!true;
        log("--- replaying 40 stuck-pixel events + 216 real events (64 batches, one dump interval) ---");

        c.fifo_push!int(169082880, WIDTH_DATA); c.fifo_push!int(169082880, WIDTH_DATA); c.fifo_push!int(169082880, WIDTH_DATA); c.fifo_push!int(169082880, WIDTH_DATA);
        c.fifo_push!int(169082880, WIDTH_DATA); c.fifo_push!int(169082880, WIDTH_DATA); c.fifo_push!int(169082880, WIDTH_DATA); c.fifo_push!int(169082880, WIDTH_DATA);
