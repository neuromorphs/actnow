import "chips/fpga/core.act";
import "core/peripherals/mem.act";
import "core/peripherals/fifo_out.act";
import "gen/file_ids.act";

// FPGA-variant correctness test for software/dvs_track/main.c's hot-pixel
// filter: replays 40 copies of one synthetic "stuck pixel" event
// (x=10, y=10, pol=1(ON), ts=0 -> packed word 17674, i.e. (1<<14)|(10<<7)|10)
// followed by the first 216 events of the same real recorded capture
// e2e_fpga_track_test.act uses (chips/fpga/dvs_capture_20260714_151049.csv)
// -- 256 events total, exactly one DUMP_INTERVAL.
//
// software/dvs_track/main.c's header explains the filter: a cell (here,
// the 4x4-pixel cell containing (10,10)) that gets retouched within
// HOT_GAP_LIMIT=4 events of its own last touch, HOT_STREAK_THRESHOLD=20
// times in a row, has its further events dropped before they reach the
// centroid/bbox/window_count. Pushing the identical word back-to-back
// means every push extends that cell's streak by exactly 1 (gap=1 every
// time), so pushes 1-19 still register normally (streak hasn't crossed
// the threshold yet) and pushes 20-40 get dropped -- 21 of the 40 -- while
// none of the 216 real events (scattered across many different cells,
// verified not to collide with the same cell or each other) are affected.
// That's exactly what's asserted below: window_count is 235 (216 real +
// only the first 19 hot-pixel touches), not the full 256, and the
// reported bounding box's min_x is 10 (from those first 19 legitimate-
// looking touches before the filter kicks in -- a real detector always
// needs a short run to recognize a pattern) while the centroid and box
// are otherwise built from real events. Both output words are asserted
// against the same math computed in Python when this file was generated.
defproc e2e_fpga_track_hotpixel_test() {
    core<4> c;

    mem<true, ROM_IMAGE> rom;
    rom.addr = c.rom_addr;
    rom.mode = c.rom_mode;
    rom.rdata = c.rom_rdata;

    fifo_out<4> fout;
    fout.addr = c.io_addr;
    fout.mode = c.io_mode;
    fout.wdata = c.io_wdata;
    fout.rdata = c.io_rdata;

    int<WIDTH_DATA> result;

    chp {
        log("======== dvs track hot-pixel filter test start (fpga) ========");
        c.reset_ext!true;
        log("--- replaying 40 stuck-pixel events + 216 real events (64 batches, one dump interval) ---");

        c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA);
        c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA);
        c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA);
        c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA);
        c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA);
        c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA);
        c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA);
        c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA);
        c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA);
        c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA); c.fifo_push!int(17674, WIDTH_DATA);
        c.fifo_push!int(21489, WIDTH_DATA); c.fifo_push!int(23029, WIDTH_DATA); c.fifo_push!int(7801, WIDTH_DATA); c.fifo_push!int(18299, WIDTH_DATA);
        c.fifo_push!int(11516, WIDTH_DATA); c.fifo_push!int(22390, WIDTH_DATA); c.fifo_push!int(11388, WIDTH_DATA); c.fifo_push!int(8186, WIDTH_DATA);
        c.fifo_push!int(5093, WIDTH_DATA); c.fifo_push!int(22970, WIDTH_DATA); c.fifo_push!int(1752, WIDTH_DATA); c.fifo_push!int(23146, WIDTH_DATA);
        c.fifo_push!int(3426, WIDTH_DATA); c.fifo_push!int(3171, WIDTH_DATA); c.fifo_push!int(9469, WIDTH_DATA); c.fifo_push!int(24021, WIDTH_DATA);
