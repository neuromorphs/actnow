        c.fifo_push!int(25061, WIDTH_DATA); c.fifo_push!int(5583, WIDTH_DATA); c.fifo_push!int(5343, WIDTH_DATA); c.fifo_push!int(25958, WIDTH_DATA);
        c.fifo_push!int(2294, WIDTH_DATA); c.fifo_push!int(22892, WIDTH_DATA); c.fifo_push!int(22867, WIDTH_DATA); c.fifo_push!int(18297, WIDTH_DATA);

        log("--- dump triggered at batch 64: popping status + bbox words ---");
        fout.pop?result; assert(result = 23080427, "status word: want 23080427 (locked=1 cx=96 cy=45 count=235 -- 21 hot-pixel events dropped), got ", result);
        fout.pop?result; assert(result = 168066410, "bbox word: want 168066410 (min=10,4 max=125,106), got ", result);

        log("======== dvs track hot-pixel filter test complete ========")
    }
}

e2e_fpga_track_hotpixel_test e2e;
