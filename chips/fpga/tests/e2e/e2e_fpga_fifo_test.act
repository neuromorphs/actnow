import "chips/fpga/soc.act";
import "core/peripherals/rom.act";
import "core/peripherals/fifo_out.act";
import "gen/file_ids.act";

open actnow::chips::fpga;
open actnow::core::peripherals;

// FPGA-variant port of chips/bench/tests/e2e/e2e_fifo_test.act: boots
// software/application/main.c through the bootloader, lets it configure its
// event_id_0 vector + input-FIFO trigger level (BATCH=4), then sleep. Two
// 4-word batches are pushed into the input FIFO (base 5); fifo_in fires the
// single interrupt itself once each batch lands, the program's ISR
// transforms each word (transform_event() in main.c) and writes the results
// out base 6, observed here.
//
// Each pushed word is a synthetic event packed per software/application/
// main.c's "Requirements event ABI" (bits 30:24 x, 23:17 y, 16:1 timestep,
// bit 0 polarity), polarity always 1 -- transform_event() silently drops
// any event whose polarity bit isn't 1, so every word here needs it set to
// get a 1:1 push:pop correspondence. Expected outputs are transform_event()'s
// actual math computed in Python against that function when this file was
// written -- see chips/bench/tests/e2e/e2e_fifo_test.act's header for the
// same reference (identical firmware, identical batches).
//
// The differences from the bench version are purely structural, and are exactly
// the three things this chip variant changes:
//   - the single interrupt (fifo_in.event_out -> event_id_0) is wired *inside*
//     chips/fpga/soc.act, so there's no `c.event_id_0 = c.fifo_event` here;
//   - the ROM is external -- modelled by a file-preloaded rom<...> on the
//     raw rom_* route (base 4) rather than living in the periphery;
//   - there is no output FIFO peripheral -- base 6 is the raw io_* route, and
//     the program's writes there are captured by a fifo_out modelled *in the
//     testbench* as the observable "outside".
defproc e2e_fpga_fifo_test() {
    soc<4> c;

    rom<ROM_IMAGE> rom;
    rom.addr = c.rom_addr;
    rom.mode = c.rom_mode;
    rom.rdata = c.rom_rdata;

    fifo_out<4> fout;
    fout.addr = c.io_addr;
    fout.mode = c.io_mode;
    fout.wdata = c.io_wdata;
    fout.rdata = c.io_rdata;

    int<WIDTH_DATA> result;
    int<32> delay;

    chp {
        log("======== end-to-end interrupt/FIFO test start (fpga) ========");

        // soc boots from a cold reset -- assert reset_ext once to kick it off.
        c.reset_ext!true;

        // Each push just blocks until the program has configured its vector
        // and trigger level; the interrupt fires itself once a batch lands.
        // Batch 1: 4 synthetic events, (x=10,y=10) (x=63,y=56) (x=0,y=0)
        // (x=120,y=100), all polarity=1.
        log("--- batch 1: pushing 4 events into the input FIFO ---");
        c.fifo_push!int(169082881, WIDTH_DATA);  // x=10,  y=10,  ts=0,  p=1
        c.fifo_push!int(1064304643, WIDTH_DATA); // x=63,  y=56,  ts=1,  p=1
        c.fifo_push!int(5, WIDTH_DATA);          // x=0,   y=0,   ts=2,  p=1
        c.fifo_push!int(2026373127, WIDTH_DATA); // x=120, y=100, ts=3,  p=1

        fout.pop?result;
        assert(result = 2043543552, "batch 1 result 1: want 2043543552, got ", result);
        fout.pop?result;
        assert(result = 1148321794, "batch 1 result 2: want 1148321794, got ", result);
        fout.pop?result;
        assert(result = 2111700996, "batch 1 result 3: want 2111700996, got ", result);
        fout.pop?result;
        assert(result = 186253318, "batch 1 result 4: want 186253318, got ", result);
        log("batch 1: got all 4 transformed events back from the base-6 output");

        // Model some real-world latency between events.
        delay := 0;
        *[ delay < 3000 -> delay := delay + 1 ];

        // --- Batch 2: 4 more synthetic events, (x=20,y=30) (x=100,y=5)
        // (x=1,y=111) (x=126,y=0), all polarity=1. Same ISR and config,
        // reused without reconfiguring anything.
        log("--- batch 2: pushing 4 events into the input FIFO ---");
        c.fifo_push!int(339476501, WIDTH_DATA);  // x=20,  y=30,  ts=10, p=1
        c.fifo_push!int(1678376983, WIDTH_DATA); // x=100, y=5,   ts=11, p=1
        c.fifo_push!int(31326233, WIDTH_DATA);   // x=1,   y=111, ts=12, p=1
        c.fifo_push!int(2113929243, WIDTH_DATA); // x=126, y=0,   ts=13, p=1

        fout.pop?result;
        assert(result = 1873149972, "batch 2 result 1: want 1873149972, got ", result);
        fout.pop?result;
        assert(result = 534249494, "batch 2 result 2: want 534249494, got ", result);
        fout.pop?result;
        assert(result = 2097414168, "batch 2 result 3: want 2097414168, got ", result);
        fout.pop?result;
        assert(result = 98435098, "batch 2 result 4: want 98435098, got ", result);
        log("batch 2: got all 4 transformed events back from the base-6 output");

        log("======== end-to-end interrupt/FIFO test complete ========")
    }
}

e2e_fpga_fifo_test e2e;
