import "chips/fpga/core.act";
import "core/peripherals/mem.act";
import "core/peripherals/fifo_out.act";
import "gen/file_ids.act";

// FPGA-variant correctness test for the time-surface detector: boots
// software/dvs_timesurface/main.c through the bootloader, then replays the
// first 256 events (64 batches -- exactly one DUMP_INTERVAL) taken verbatim
// from the real recorded capture (chips/fpga/data/dvs_capture_20260714_151049.csv,
// packed the same way evt_pack.v would on real hardware) through the input
// FIFO (base 5), same replay-a-capture-file pattern as
// e2e_fpga_rotate_test.act / e2e_fpga_motion_test.act.
//
// isr_handler never writes to the output FIFO except on the DUMP_INTERVAL-th
// batch -- see software/dvs_timesurface/main.c's header. This test's 256
// events cross exactly one dump boundary (batch 64), so after all 256 pushes
// the ISR has written 897 words: `now` (the running event counter, 256),
// then all GRID_CELLS=896 cells' last_seen values, row-major. Every one of
// those 897 words is asserted against the same grid math computed in Python
// when this file was generated, proving the ISR's per-cell stamping matches
// the reference model bit-for-bit -- including the 719 cells no event ever
// landed in, which must still read back exactly 0.
defproc e2e_fpga_timesurface_test() {
    core<4> c;

    mem<true, ROM_IMAGE> rom;
    rom.addr = c.rom_addr;
    rom.mode = c.rom_mode;
    rom.rdata = c.rom_rdata;

    fifo_out<4> fout;
    fout.addr = c.io_addr;
    fout.mode = c.io_mode;
    fout.wdata = c.io_wdata;
    fout.rdata = c.io_rdata;

    int<WIDTH_DATA> result;

    chp {
        log("======== dvs timesurface e2e test start (fpga) ========");
        c.reset_ext!true;
