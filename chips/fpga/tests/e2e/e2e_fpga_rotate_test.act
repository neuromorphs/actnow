        fout.pop?result; assert(result = 6880, "rep 0 event 36: want 6880, got ", result); fout.pop?result; assert(result = 7900, "rep 0 event 37: want 7900, got ", result); fout.pop?result; assert(result = 26201, "rep 0 event 38: want 26201, got ", result); fout.pop?result; assert(result = 7516, "rep 0 event 39: want 7516, got ", result);
        c.fifo_push!int(25272, WIDTH_DATA); c.fifo_push!int(9553, WIDTH_DATA); c.fifo_push!int(10100, WIDTH_DATA); c.fifo_push!int(17273, WIDTH_DATA);
        fout.pop?result; assert(result = 23989, "rep 0 event 40: want 23989, got ", result); fout.pop?result; assert(result = 9535, "rep 0 event 41: want 9535, got ", result); fout.pop?result; assert(result = 11982, "rep 0 event 42: want 11982, got ", result); fout.pop?result; assert(result = 24181, "rep 0 event 43: want 24181, got ", result);
