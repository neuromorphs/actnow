import "chips/fpga/core.act";
import "core/peripherals/mem.act";
import "core/peripherals/fifo_out.act";
import "gen/file_ids.act";

// FPGA-variant "real-life" test: boots software/dvs_rotate/main.c through the
// bootloader, then replays 200 events taken verbatim from a real recorded
// capture (chips/fpga/dvs_capture_20260714_151049.csv, packed the same way
// evt_pack.v would on real hardware -- each literal below is one event's raw
// base-5 FIFO word: evt_pack.v's low 15 bits, {pol,y[6:0],x[6:0]} -- this
// capture has no per-event timestamp, so the top 17 ts bits are 0, which is
// exactly what kr260_capture.py's "le" column already is) through the input
// FIFO (base 5) three times in a row, the way dvs_replay.py's --loop replays a
// capture file for a live viewer.
//
// The program's ISR rotates each event's (x,y) 45 degrees
// (software/dvs_rotate/main.c's shift-based, multiply-free rotation:
// (x-cx,y-cy) -> ((tx-ty)>>1, (tx+ty)>>1) -> +center, clamped to [0,125]x[0,111])
// and writes the result to the raw base-6 output, observed here exactly like
// e2e_fpga_fifo_test. Every one of the 600 results (200 events x 3 reps) is
// asserted against the same rotation computed in Python when this file was
// generated -- proving the ISR's rotation matches the reference math and that
// the same capture can be pushed through repeatedly without drift. Indices are
// literal constants rather than a runtime loop because ACT does not permit
// dynamic dereference of pint (parameter-array) literals -- see the FATAL
// "Dynamic de-reference of parameter arrays not permitted" this replaced.
defproc e2e_fpga_rotate_test() {
    core<4> c;

    mem<true, ROM_IMAGE> rom;
    rom.addr = c.rom_addr;
    rom.mode = c.rom_mode;
    rom.rdata = c.rom_rdata;

    fifo_out<4> fout;
    fout.addr = c.io_addr;
    fout.mode = c.io_mode;
    fout.wdata = c.io_wdata;
    fout.rdata = c.io_rdata;

    int<WIDTH_DATA> result;

    chp {
        log("======== dvs rotate-45 e2e test start (fpga) ========");

        // Cold boot: soc.act blocks on reset_ext before it does anything at
        // all (core/soc.act:129), so this has to fire once before the first
        // push -- e2e_fpga_fifo_test's own missing-reset_ext gap is a
        // separate known issue, not one this new test should copy.
        c.reset_ext!true;

        log("--- replaying 200 recorded events, 3 loops ---");

        // --- rep 0 ---
        c.fifo_push!int(21489, WIDTH_DATA); c.fifo_push!int(23029, WIDTH_DATA); c.fifo_push!int(7801, WIDTH_DATA); c.fifo_push!int(18299, WIDTH_DATA);
        fout.pop?result; assert(result = 25696, "rep 0 event 0: want 25696, got ", result); fout.pop?result; assert(result = 26716, "rep 0 event 1: want 26716, got ", result); fout.pop?result; assert(result = 11226, "rep 0 event 2: want 11226, got ", result); fout.pop?result; assert(result = 24818, "rep 0 event 3: want 24818, got ", result);
        c.fifo_push!int(11516, WIDTH_DATA); c.fifo_push!int(22390, WIDTH_DATA); c.fifo_push!int(11388, WIDTH_DATA); c.fifo_push!int(8186, WIDTH_DATA);
        fout.pop?result; assert(result = 13261, "rep 0 event 4: want 13261, got ", result); fout.pop?result; assert(result = 26463, "rep 0 event 5: want 26463, got ", result); fout.pop?result; assert(result = 13133, "rep 0 event 6: want 13133, got ", result); fout.pop?result; assert(result = 11481, "rep 0 event 7: want 11481, got ", result);
        c.fifo_push!int(5093, WIDTH_DATA); c.fifo_push!int(22970, WIDTH_DATA); c.fifo_push!int(1752, WIDTH_DATA); c.fifo_push!int(23146, WIDTH_DATA);
        fout.pop?result; assert(result = 8538, "rep 0 event 8: want 8538, got ", result); fout.pop?result; assert(result = 22975, "rep 0 event 9: want 22975, got ", result); fout.pop?result; assert(result = 6113, "rep 0 event 10: want 6113, got ", result); fout.pop?result; assert(result = 26070, "rep 0 event 11: want 26070, got ", result);
        c.fifo_push!int(3426, WIDTH_DATA); c.fifo_push!int(3171, WIDTH_DATA); c.fifo_push!int(9469, WIDTH_DATA); c.fifo_push!int(24021, WIDTH_DATA);
        fout.pop?result; assert(result = 7519, "rep 0 event 12: want 7519, got ", result); fout.pop?result; assert(result = 7521, "rep 0 event 13: want 7521, got ", result); fout.pop?result; assert(result = 12245, "rep 0 event 14: want 12245, got ", result); fout.pop?result; assert(result = 25160, "rep 0 event 15: want 25160, got ", result);
        c.fifo_push!int(5565, WIDTH_DATA); c.fifo_push!int(5349, WIDTH_DATA); c.fifo_push!int(2122, WIDTH_DATA); c.fifo_push!int(5945, WIDTH_DATA);
        fout.pop?result; assert(result = 6212, "rep 0 event 16: want 6212, got ", result); fout.pop?result; assert(result = 8665, "rep 0 event 17: want 8665, got ", result); fout.pop?result; assert(result = 5336, "rep 0 event 18: want 5336, got ", result); fout.pop?result; assert(result = 6209, "rep 0 event 19: want 6209, got ", result);
        c.fifo_push!int(26057, WIDTH_DATA); c.fifo_push!int(5180, WIDTH_DATA); c.fifo_push!int(13641, WIDTH_DATA); c.fifo_push!int(26829, WIDTH_DATA);
        fout.pop?result; assert(result = 25402, "rep 0 event 20: want 25402, got ", result); fout.pop?result; assert(result = 5957, "rep 0 event 21: want 5957, got ", result); fout.pop?result; assert(result = 11051, "rep 0 event 22: want 11051, got ", result); fout.pop?result; assert(result = 26041, "rep 0 event 23: want 26041, got ", result);
        c.fifo_push!int(7649, WIDTH_DATA); c.fifo_push!int(9948, WIDTH_DATA); c.fifo_push!int(2012, WIDTH_DATA); c.fifo_push!int(9031, WIDTH_DATA);
        fout.pop?result; assert(result = 9550, "rep 0 event 24: want 9550, got ", result); fout.pop?result; assert(result = 10435, "rep 0 event 25: want 10435, got ", result); fout.pop?result; assert(result = 6498, "rep 0 event 26: want 6498, got ", result); fout.pop?result; assert(result = 8636, "rep 0 event 27: want 8636, got ", result);
        c.fifo_push!int(4558, WIDTH_DATA); c.fifo_push!int(22848, WIDTH_DATA); c.fifo_push!int(9177, WIDTH_DATA); c.fifo_push!int(2773, WIDTH_DATA);
        fout.pop?result; assert(result = 6865, "rep 0 event 28: want 6865, got ", result); fout.pop?result; assert(result = 23234, "rep 0 event 29: want 23234, got ", result); fout.pop?result; assert(result = 9796, "rep 0 event 30: want 9796, got ", result); fout.pop?result; assert(result = 6363, "rep 0 event 31: want 6363, got ", result);
        c.fifo_push!int(3910, WIDTH_DATA); c.fifo_push!int(1605, WIDTH_DATA); c.fifo_push!int(3291, WIDTH_DATA); c.fifo_push!int(9077, WIDTH_DATA);
        fout.pop?result; assert(result = 5967, "rep 0 event 32: want 5967, got ", result); fout.pop?result; assert(result = 4824, "rep 0 event 33: want 4824, got ", result); fout.pop?result; assert(result = 7004, "rep 0 event 34: want 7004, got ", result); fout.pop?result; assert(result = 11603, "rep 0 event 35: want 11603, got ", result);
