        c.fifo_push!int(25532, WIDTH_DATA); c.fifo_push!int(1488, WIDTH_DATA); c.fifo_push!int(23151, WIDTH_DATA); c.fifo_push!int(3410, WIDTH_DATA);
        fout.pop?result; assert(result = 24374, "rep 0 event 56: want 24374, got ", result); fout.pop?result; assert(result = 5470, "rep 0 event 57: want 5470, got ", result); fout.pop?result; assert(result = 26457, "rep 0 event 58: want 26457, got ", result); fout.pop?result; assert(result = 6487, "rep 0 event 59: want 6487, got ", result);
