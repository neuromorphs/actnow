import "chips/fpga/soc.act";
import "assets/peripherals/rom.act";
import "assets/peripherals/fifo_out.act";
import "gen/file_ids.act";

open actnow::chips::fpga;
open actnow::peripherals;

// FPGA-variant port of chips/bench/tests/e2e/e2e_reset_test.act: exercises
// assets/core/cpu.act's reset_ext through the real bootloader + software/application.
//
// Sequence: boot, run one batch through the program's real ISR (same as
// e2e_fpga_fifo_test's batch 1), fire external reset, then run the identical
// batch again. Reset clears the interrupt controller's vector table and
// enable mask but leaves internal RAM untouched, so the same bootloader+
// application image re-runs from scratch: the bootloader re-copies
// application into SRAM, which re-registers its ISR vector, re-configures
// fifo_in's trigger level, and re-enables event_id_0. If any of that didn't
// genuinely reset, the second batch would hang or misbehave.
//
// Same structural adaptations as e2e_fpga_fifo_test: interrupt wired inside
// soc, ROM modelled externally on the raw route, base-6 output captured by a
// testbench fifo_out.
defproc e2e_fpga_reset_test() {
    soc<4> c;

    rom<ROM_IMAGE> rom;
    rom.addr = c.rom_addr;
    rom.mode = c.rom_mode;
    rom.rdata = c.rom_rdata;

    fifo_out<4> fout;
    fout.addr = c.io_addr;
    fout.mode = c.io_mode;
    fout.wdata = c.io_wdata;
    fout.rdata = c.io_rdata;

    int<WIDTH_DATA> result;
    int<32> delay;

    chp {
        log("======== reset e2e test start (fpga) ========");

        // soc boots from a cold reset -- assert reset_ext once to boot it. Distinct
        // from the mid-test reset_ext below, which is the reboot this test proves.
        c.reset_ext!true;

        // --- Batch 1: identical to e2e_fpga_fifo_test's batch 1 -- 4
        // synthetic events, (x=10,y=10) (x=63,y=56) (x=0,y=0) (x=120,y=100),
        // all polarity=1 (see that file's header for the packing/transform
        // reference).
        log("--- batch 1: pushing 4 events into the input FIFO ---");
        c.fifo_push!int(169082881, WIDTH_DATA);  // x=10,  y=10,  ts=0,  p=1
        c.fifo_push!int(1064304643, WIDTH_DATA); // x=63,  y=56,  ts=1,  p=1
        c.fifo_push!int(5, WIDTH_DATA);          // x=0,   y=0,   ts=2,  p=1
        c.fifo_push!int(2026373127, WIDTH_DATA); // x=120, y=100, ts=3,  p=1

        fout.pop?result;
        assert(result = 2043543552, "batch 1 result 1: want 2043543552, got ", result);
        fout.pop?result;
        assert(result = 1148321794, "batch 1 result 2: want 1148321794, got ", result);
        fout.pop?result;
        assert(result = 2111700996, "batch 1 result 3: want 2111700996, got ", result);
        fout.pop?result;
        assert(result = 186253318, "batch 1 result 4: want 186253318, got ", result);
        log("batch 1: got all 4 transformed events back from the base-6 output");

        delay := 0;
        *[ delay < 3000 -> delay := delay + 1 ];

        log("--- asserting external reset ---");
        c.reset_ext!true;
        log("--- reset done -- bootloader + application should now be rebooting from scratch ---");

        // --- Batch 2: push the same 4 events again. Only passes if the
        // rebooted application genuinely re-registered its ISR vector,
        // trigger level, and enable bit from a clean interrupt controller.
        log("--- batch 2 (post-reset): pushing the same 4 events into the input FIFO ---");
        c.fifo_push!int(169082881, WIDTH_DATA);  // x=10,  y=10,  ts=0,  p=1
        c.fifo_push!int(1064304643, WIDTH_DATA); // x=63,  y=56,  ts=1,  p=1
        c.fifo_push!int(5, WIDTH_DATA);          // x=0,   y=0,   ts=2,  p=1
        c.fifo_push!int(2026373127, WIDTH_DATA); // x=120, y=100, ts=3,  p=1

        fout.pop?result;
        assert(result = 2043543552, "batch 2 result 1: want 2043543552, got ", result);
        fout.pop?result;
        assert(result = 1148321794, "batch 2 result 2: want 1148321794, got ", result);
        fout.pop?result;
        assert(result = 2111700996, "batch 2 result 3: want 2111700996, got ", result);
        fout.pop?result;
        assert(result = 186253318, "batch 2 result 4: want 186253318, got ", result);
        log("batch 2: got all 4 transformed events back from the base-6 output -- real reboot after reset confirmed");

        log("======== reset e2e test complete ========")
    }
}

e2e_fpga_reset_test ert;
