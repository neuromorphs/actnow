import "chips/fpga/core.act";
import "core/peripherals/mem.act";
import "core/peripherals/fifo_out.act";
import "gen/file_ids.act";

// FPGA-variant port of chips/bench/tests/e2e/e2e_reset_test.act: exercises
// core/soc.act's reset_ext through the real bootloader + software/application.
//
// Sequence: boot, run one batch through the program's real ISR (same as
// e2e_fpga_fifo_test's batch 1), fire external reset, then run a second batch.
// Reset clears the interrupt controller's vector table and enable mask but
// leaves internal RAM untouched, so the same bootloader+application image
// re-runs from scratch: the bootloader re-copies application into SRAM, which
// re-registers its ISR vector, re-configures fifo_in's trigger level, and
// re-enables event_id_0. If any of that didn't genuinely reset, the second
// batch would hang or misbehave.
//
// Same structural adaptations as e2e_fpga_fifo_test: interrupt wired inside
// core, ROM modelled externally on the raw route, base-6 output captured by a
// testbench fifo_out.
defproc e2e_fpga_reset_test() {
    core<4> c;

    mem<true, ROM_IMAGE> rom;
    rom.addr = c.rom_addr;
    rom.mode = c.rom_mode;
    rom.rdata = c.rom_rdata;

    fifo_out<4> fout;
    fout.addr = c.io_addr;
    fout.mode = c.io_mode;
    fout.wdata = c.io_wdata;
    fout.rdata = c.io_rdata;

    int<WIDTH_DATA> result;
    int<32> delay;

    chp {
        log("======== reset e2e test start (fpga) ========");

        // soc no longer boots itself -- assert reset_ext once to boot it. Distinct
        // from the mid-test reset_ext below, which is the reboot this test proves.
        c.reset_ext!true;

        // --- Batch 1: push 41, 42, 43, ISR computes +1 on each.
        log("--- batch 1: pushing 41, 42, 43 into the input FIFO ---");
        c.fifo_push!int(41, WIDTH_DATA);
        c.fifo_push!int(42, WIDTH_DATA);
        c.fifo_push!int(43, WIDTH_DATA);

        fout.pop?result;
        assert(result = 42, "batch 1 result 1: want 42, got ", result);
        fout.pop?result;
        assert(result = 43, "batch 1 result 2: want 43, got ", result);
        fout.pop?result;
        assert(result = 44, "batch 1 result 3: want 44, got ", result);
        log("batch 1: got 42, 43, 44 back from the base-6 output");

        delay := 0;
        *[ delay < 3000 -> delay := delay + 1 ];

        log("--- asserting external reset ---");
        c.reset_ext!true;
        log("--- reset done -- bootloader + application should now be rebooting from scratch ---");

        // --- Batch 2: push 41, 42, 43 again. Only passes if the rebooted
        // application genuinely re-registered its ISR vector, trigger level,
        // and enable bit from a clean interrupt controller.
        log("--- batch 2 (post-reset): pushing 41, 42, 43 into the input FIFO ---");
        c.fifo_push!int(41, WIDTH_DATA);
        c.fifo_push!int(42, WIDTH_DATA);
        c.fifo_push!int(43, WIDTH_DATA);

        fout.pop?result;
        assert(result = 42, "batch 2 result 1: want 42, got ", result);
        fout.pop?result;
        assert(result = 43, "batch 2 result 2: want 43, got ", result);
        fout.pop?result;
        assert(result = 44, "batch 2 result 3: want 44, got ", result);
        log("batch 2: got 42, 43, 44 back from the base-6 output -- real reboot after reset confirmed");

        log("======== reset e2e test complete ========")
    }
}

e2e_fpga_reset_test ert;
