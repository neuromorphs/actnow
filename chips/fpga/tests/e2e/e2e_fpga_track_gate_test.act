import "chips/fpga/soc.act";
import "core/peripherals/mem.act";
import "core/peripherals/fifo_out.act";
import "gen/file_ids.act";

// FPGA-variant correctness test for software/dvs_track/main.c's tracking
// gate: proves a locked-on window's bounding box stays tight around the
// real object instead of ballooning out to include unrelated activity
// elsewhere in the frame -- see that file's header for why the gate exists
// (a real 173k-event recording showed near-full-sensor boxes every window
// without it) and how it works (Chebyshev distance from the current
// centre, only enforced once a window has actually locked on, reset wide
// open to search again after any window that fails to lock).
//
// Pushed words are packed per main.c's actual decode -- x in bits [30:24],
// y in bits [23:17], polarity in bit 0 (X_SHIFT=24/Y_SHIFT=17, same ABI as
// chips/bench/tests/e2e/e2e_fifo_test.act and the other dvs_track tests in
// this directory) -- NOT evt_pack.v's unrelated 15-bit {pol,y,x} scheme.
// GATE_RADIUS is the current build default (50, no -DGATE_RADIUS override
// in chips/fpga/Makefile's ROM_TEST=dvs_track rule).
//
// Window 1 (256 events, one DUMP_INTERVAL): 32 cycles of an 8-point cluster
// packed into a tight 2x2 block of 4x4-pixel cells at x in [60,66],
// y in [48,54] -- comfortably clears LOCK_THRESHOLD=32. count is 252, not
// 256: the correlation (noise) filter needs 2 recently-touched neighbour
// cells to admit an event, and on a cold start nothing has been touched
// yet, so the very first cycle's 4 first-touches at previously-untouched
// cells are rejected before the other cells in the block have any history
// to lend support; every following cycle has full cross-cell support.
//
// Window 2 (256 events): 200 more events from the *same* cluster (25 more
// cycles, gate_active from window 1 keeps all 200 admitted -- identical
// cluster is trivially within GATE_RADIUS) plus 56 events from an
// unrelated cluster near (120,10) -- Chebyshev distance ~58 from window 1's
// locked-on centre (64,52), outside GATE_RADIUS=50. If the gate weren't
// working, the bounding box would balloon out to include (120,10);
// instead every one of those 56 events is rejected, leaving window 2's
// bbox identical to window 1's tight cluster and window_count at exactly
// 200 (all 200 near-cluster events, 0 of the 56 far ones). Both windows'
// output words are asserted against the same math (a direct Python port of
// main.c's TRACK_ALGO=1 median+MAD/gate/correlation-filter logic) computed
// when this file was generated.
defproc e2e_fpga_track_gate_test() {
    soc<4> c;

    mem<true, ROM_IMAGE> rom;
    rom.addr = c.rom_addr;
    rom.mode = c.rom_mode;
    rom.rdata = c.rom_rdata;

    fifo_out<4> fout;
    fout.addr = c.io_addr;
    fout.mode = c.io_mode;
    fout.wdata = c.io_wdata;
    fout.rdata = c.io_rdata;

    int<WIDTH_DATA> result;

    chp {
        log("======== dvs track gate test start (fpga) ========");
        c.reset_ext!true;
        log("--- window 1: 256 events, tight cluster near (64,52) -- should lock ---");

        c.fifo_push!int(1012924417, WIDTH_DATA); c.fifo_push!int(1046740993, WIDTH_DATA); c.fifo_push!int(1080033281, WIDTH_DATA); c.fifo_push!int(1113849857, WIDTH_DATA);
        c.fifo_push!int(1013448705, WIDTH_DATA); c.fifo_push!int(1047265281, WIDTH_DATA); c.fifo_push!int(1080557569, WIDTH_DATA); c.fifo_push!int(1114374145, WIDTH_DATA);
