import "chips/fpga/core.act";
import "core/peripherals/mem.act";
import "core/peripherals/fifo_out.act";
import "gen/file_ids.act";

// FPGA-variant "real-life" test for the motion detector: boots
// software/dvs_motion/main.c through the bootloader, then replays
// 200 events taken verbatim from a real recorded capture
// (chips/fpga/dvs_capture_20260714_151049.csv, packed the same way
// evt_pack.v would on real hardware) through the input FIFO (base 5)
// 3 times in a row -- same replay-a-capture-file pattern as
// e2e_fpga_rotate_test.act.
//
// Unlike the rotation ISR, dvs_motion writes exactly one status word per
// BATCH=4-event batch (a decaying per-cell activity grid's argmax), not one
// word per event -- see software/dvs_motion/main.c's header for the grid
// math (16x16-pixel cells, 8x8 grid, shift-only indexing, no multiply/
// divide). Every one of the 150 status words is
// asserted against the same grid math computed in Python when this file was
// generated, with the grid state carried across all 3 reps exactly
// like the firmware's static array -- proving the ISR's aggregate tracking
// matches the reference model bit-for-bit. Indices are literal constants
// rather than a runtime loop because ACT does not permit dynamic
// dereference of pint (parameter-array) literals.
defproc e2e_fpga_motion_test() {
    core<4> c;

    mem<true, ROM_IMAGE> rom;
    rom.addr = c.rom_addr;
    rom.mode = c.rom_mode;
    rom.rdata = c.rom_rdata;

    fifo_out<4> fout;
    fout.addr = c.io_addr;
    fout.mode = c.io_mode;
    fout.wdata = c.io_wdata;
    fout.rdata = c.io_rdata;

    int<WIDTH_DATA> result;

    chp {
        log("======== dvs motion-grid e2e test start (fpga) ========");
        c.reset_ext!true;
        log("--- replaying 200 recorded events, 3 loops ---");

        // --- rep 0 ---
        c.fifo_push!int(21489, WIDTH_DATA); c.fifo_push!int(23029, WIDTH_DATA); c.fifo_push!int(7801, WIDTH_DATA); c.fifo_push!int(18299, WIDTH_DATA);
        fout.pop?result; assert(result = 22539, "rep 0 word 0: want 22539, got ", result);
        c.fifo_push!int(11516, WIDTH_DATA); c.fifo_push!int(22390, WIDTH_DATA); c.fifo_push!int(11388, WIDTH_DATA); c.fifo_push!int(8186, WIDTH_DATA);
        fout.pop?result; assert(result = 23563, "rep 0 word 1: want 23563, got ", result);
