import "chips/fpga/core.act";
import "core/peripherals/mem.act";
import "core/peripherals/fifo_out.act";
import "gen/file_ids.act";

// FPGA-variant correctness test for the object-centroid/bounding-box
// tracker: boots software/dvs_track/main.c through the bootloader, then
// replays the same 256 events (64 batches -- exactly one DUMP_INTERVAL)
// from the real recorded capture that e2e_fpga_denoise_test.act uses
// (chips/fpga/dvs_capture_20260714_151049.csv), through the input FIFO
// (base 5). Each event is packed in the hardware ABI evt_pack.v produces --
// x in bits [30:24], y in [23:17] -- exactly what dvs_track/main.c decodes,
// so this exercises the same coordinate path the FPGA does.
//
// After all 256 pushes the ISR has written 2 words: a status word
// (locked<<24 | cx<<16 | cy<<8 | count) and a bounding-box word
// (min_x<<24 | min_y<<16 | max_x<<8 | max_y) -- see software/dvs_track/
// main.c's header for the exact packing and the EMA-centroid/window-bbox
// math. Both are asserted against the same math computed in Python when
// this file was generated (spatio-temporal correlation filter with
// CORR_WINDOW=30/CORR_MIN=2, then over the last TRACK_N=256 surviving events:
// median x/y for the centre and box = median +/- BOX_K=2 * MAD, where MAD is
// the median absolute deviation; LOCK_THRESHOLD=32), proving the ISR's tracker
// matches the reference model bit-for-bit. The correlation filter drops the
// scattered events, so count=40 (of 256) and the median/MAD box is a robust,
// tight box around the moving object, not the whole frame.
defproc e2e_fpga_track_test() {
    core<4> c;

    mem<true, ROM_IMAGE> rom;
    rom.addr = c.rom_addr;
    rom.mode = c.rom_mode;
    rom.rdata = c.rom_rdata;

    fifo_out<4> fout;
    fout.addr = c.io_addr;
    fout.mode = c.io_mode;
    fout.wdata = c.io_wdata;
    fout.rdata = c.io_rdata;

    int<WIDTH_DATA> result;

    chp {
        log("======== dvs track e2e test start (fpga) ========");
        c.reset_ext!true;
        log("--- replaying 256 recorded events (64 batches, one dump interval) ---");

        c.fifo_push!int(1900937216, WIDTH_DATA); c.fifo_push!int(1969618944, WIDTH_DATA); c.fifo_push!int(2037907456, WIDTH_DATA); c.fifo_push!int(2065432576, WIDTH_DATA);
        c.fifo_push!int(2092040192, WIDTH_DATA); c.fifo_push!int(1985740800, WIDTH_DATA); c.fifo_push!int(2091909120, WIDTH_DATA); c.fifo_push!int(2055077888, WIDTH_DATA);
