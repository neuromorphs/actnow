import "chips/fpga/core.act";
import "core/peripherals/mem.act";
import "core/peripherals/fifo_out.act";
import "gen/file_ids.act";

// FPGA-variant correctness test for the object-centroid/bounding-box
// tracker: boots software/dvs_track/main.c through the bootloader, then
// replays the same 256 events (64 batches -- exactly one DUMP_INTERVAL)
// taken verbatim from the real recorded capture
// (chips/fpga/dvs_capture_20260714_151049.csv, packed the same way
// evt_pack.v would on real hardware) that e2e_fpga_denoise_test.act uses,
// through the input FIFO (base 5).
//
// After all 256 pushes the ISR has written 2 words: a status word
// (locked<<24 | cx<<16 | cy<<8 | count) and a bounding-box word
// (min_x<<24 | min_y<<16 | max_x<<8 | max_y) -- see software/dvs_track/
// main.c's header for the exact packing and the EMA-centroid/window-bbox
// math. Both are asserted against the same math computed in Python when
// this file was generated (FRAC=4 fixed-point EMA, EMA_SHIFT=3, plain
// min/max bounding box, LOCK_THRESHOLD=32), proving the ISR's tracker
// matches the reference model bit-for-bit.
defproc e2e_fpga_track_test() {
    core<4> c;

    mem<true, ROM_IMAGE> rom;
    rom.addr = c.rom_addr;
    rom.mode = c.rom_mode;
    rom.rdata = c.rom_rdata;

    fifo_out<4> fout;
    fout.addr = c.io_addr;
    fout.mode = c.io_mode;
    fout.wdata = c.io_wdata;
    fout.rdata = c.io_rdata;

    int<WIDTH_DATA> result;

    chp {
        log("======== dvs track e2e test start (fpga) ========");
        c.reset_ext!true;
        log("--- replaying 256 recorded events (64 batches, one dump interval) ---");

