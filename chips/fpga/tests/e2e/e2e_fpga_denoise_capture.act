import "chips/fpga/soc.act";
import "core/peripherals/rom.act";
import "core/peripherals/fifo_out.act";
import "gen/file_ids.act";
import sim;

// Not a pass/fail test -- a capture generator for a live denoised-timesurface
// viewer, mirroring e2e_fpga_timesurface_capture.act's structure exactly
// (same DUMP_INTERVAL=64 cadence, same 897-word dump layout), just against
// software/dvs_denoise/main.c's ISR instead. See that capture file's
// header for why this testbench mirrors the firmware's own dump_ctr
// power-of-2 cadence rather than popping unconditionally every batch.
// Every dump's 897 words (now + GRID_CELLS=896 signal_seen cells) are
// appended to denoise_capture_results.mem, one value per line.
defproc e2e_fpga_denoise_capture() {
    soc<4> c;

    rom<ROM_IMAGE> rom;
    rom.addr = c.rom_addr;
    rom.mode = c.rom_mode;
    rom.rdata = c.rom_rdata;

    fifo_out<4> fout;
    fout.addr = c.io_addr;
    fout.mode = c.io_mode;
    fout.wdata = c.io_wdata;
    fout.rdata = c.io_rdata;

    pint DUMP_INTERVAL = 64;
    pint DUMP_WORDS = 897;   // 1 ("now") + GRID_CELLS=896

    int<WIDTH_DATA> result;
    int<64> ev;
    int<32> reader_id, writer_id;
    int<32> batch_count, dump_i;
    int<7> dump_ctr;
    bool ok;

    chp {
        log("======== dvs denoise capture start (fpga) ========");
        c.reset_ext!true;

        reader_id := sim::file::openr(ROTATE_CAPTURE_EVENTS);
        assert(reader_id != 0, "capture: failed to open event capture file");
        writer_id := sim::file::openw(DENOISE_CAPTURE_RESULTS);
        assert(writer_id != 0, "capture: failed to open result capture file");

        batch_count := 0; dump_ctr := 0;

        *[ ~sim::file::eof(reader_id) ->
            ev := sim::file::read(reader_id); c.fifo_push!int(ev, WIDTH_DATA);
            ev := sim::file::read(reader_id); c.fifo_push!int(ev, WIDTH_DATA);
            ev := sim::file::read(reader_id); c.fifo_push!int(ev, WIDTH_DATA);
            ev := sim::file::read(reader_id); c.fifo_push!int(ev, WIDTH_DATA);

            batch_count := batch_count + 1;
            dump_ctr := dump_ctr + 1;

            [ dump_ctr = DUMP_INTERVAL ->
                dump_ctr := 0;
                dump_i := 0;
                *[ dump_i < DUMP_WORDS ->
                    fout.pop?result; ok := sim::file::write(writer_id, int(result, 64));
                    dump_i := dump_i + 1
                ]
              [] else -> skip
            ]
        ];

        ok := sim::file::closer(reader_id);
        ok := sim::file::closew(writer_id);

        log("======== dvs denoise capture complete ========")
    }
}

e2e_fpga_denoise_capture e2e;
