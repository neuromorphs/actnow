import "chips/bench/core.act";
import "gen/file_ids.act";

// Boots a real compiled program (software/application/main.c) through the
// bootloader, lets it configure its own interrupt vector and input FIFO
// trigger level (BATCH=3), then go to sleep. Pushes two separate 3-word
// batches into the input FIFO (with a delay between them) -- fifo_in fires
// the interrupt itself once each batch lands, no manual triggering here.
// Each batch is processed by the program's own ISR and observed as 3
// results on the output FIFO.
//
// `c.event_id_0 = c.fifo_event` wires fifo_in's auto-fire to event_id_0,
// matching real chips/bench wiring (unlike e2e_multi_event_test.act, which
// drives all 16 event lines manually and leaves fifo_event disconnected).
defproc e2e_fifo_test() {
    core<ROM_IMAGE> c;
    c.event_id_0 = c.fifo_event;

    int<WIDTH_DATA> result;
    int<32> delay;

    chp {
        log("======== end-to-end interrupt/FIFO test start ========");

        // soc boots from a cold reset -- assert reset_ext once to kick it off.
        c.reset_ext!true;

        // No boot-completion delay needed: each push below just blocks
        // until the program has configured its vector and trigger level,
        // and the interrupt fires itself once a batch lands.

        // --- Batch 1: push 41, 42, 43 -- ISR computes +1 on each, expect
        // 42, 43, 44 out.
        log("--- batch 1: pushing 41, 42, 43 into the input FIFO ---");
        c.push!int(41, WIDTH_DATA);
        c.push!int(42, WIDTH_DATA);
        c.push!int(43, WIDTH_DATA);

        c.pop?result;
        assert(result = 42, "batch 1 result 1: want 42, got ", result);
        c.pop?result;
        assert(result = 43, "batch 1 result 2: want 43, got ", result);
        c.pop?result;
        assert(result = 44, "batch 1 result 3: want 44, got ", result);
        log("batch 1: got 42, 43, 44 back from the output FIFO");

        // Model some real-world latency between events.
        delay := 0;
        *[ delay < 3000 -> delay := delay + 1 ];

        // --- Batch 2: push 100, 200, 300, expect 101, 201, 301 out. Same
        // ISR and config, reused without reconfiguring anything.
        log("--- batch 2: pushing 100, 200, 300 into the input FIFO ---");
        c.push!int(100, WIDTH_DATA);
        c.push!int(200, WIDTH_DATA);
        c.push!int(300, WIDTH_DATA);

        c.pop?result;
        assert(result = 101, "batch 2 result 1: want 101, got ", result);
        c.pop?result;
        assert(result = 201, "batch 2 result 2: want 201, got ", result);
        c.pop?result;
        assert(result = 301, "batch 2 result 3: want 301, got ", result);
        log("batch 2: got 101, 201, 301 back from the output FIFO");

        log("======== end-to-end interrupt/FIFO test complete ========")
    }
}

e2e_fifo_test e2e;
