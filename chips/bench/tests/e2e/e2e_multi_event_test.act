import "chips/bench/soc.act";
import "gen/file_ids.act";

open actnow::chips::bench;

// Generality/stress test: boots a real compiled program
// (software/multi_event/main.c) that registers a distinct ISR for every
// one of the 16 maskable event lines (ISR N: out = in + (N+1)). Fires all
// 16 events in turn -- one at a time, since this architecture has no
// preemption -- and checks each one's distinct response, building
// confidence that vector configuration, the enable mask, and dispatch work
// across the full width of the interrupt controller, not just the one or
// two lines the other tests exercise.
//
// soc's event_id_N ports are individually named (not an array), so this
// wires each into a local channel array (event_ch) purely so the driving
// loop can index it with a runtime variable. `c.fifo_event` is deliberately
// left unconnected: fifo_in can only auto-fire one event line, and this
// test's point is exercising all sixteen manually instead (see
// software/multi_event/main.c for why its trigger_level is set
// unreachable). Lines 14/15 are driven through `c.gpio_in_0`/`c.gpio_in_1`
// -- pure wiring onto event_id_14/event_id_15 (see soc.act) -- so firing
// them here is no different from any other line, just under their
// GPIO-facing name.
defproc e2e_multi_event_test() {
    soc<ROM_IMAGE> c;

    chan(bool) event_ch[16];
    event_ch[0] = c.event_id_0;
    event_ch[1] = c.event_id_1;
    event_ch[2] = c.event_id_2;
    event_ch[3] = c.event_id_3;
    event_ch[4] = c.event_id_4;
    event_ch[5] = c.event_id_5;
    event_ch[6] = c.event_id_6;
    event_ch[7] = c.event_id_7;
    event_ch[8] = c.event_id_8;
    event_ch[9] = c.event_id_9;
    event_ch[10] = c.event_id_10;
    event_ch[11] = c.event_id_11;
    event_ch[12] = c.event_id_12;
    event_ch[13] = c.event_id_13;
    event_ch[14] = c.gpio_in_0;
    event_ch[15] = c.gpio_in_1;

    int<WIDTH_DATA> pushed, result, expected;
    int<5> i;
    int<32> delay;

    chp {
        log("======== 16-event generality test start ========");

        // soc boots from a cold reset -- assert reset_ext once to kick it off.
        c.reset_ext!true;

        i := 0;
        *[ i < 16 ->
            pushed := int(100, WIDTH_DATA) + int(i, WIDTH_DATA);
            expected := pushed + int(i, WIDTH_DATA) + 1;

            c.push!pushed;
            [ ([]k:16: i = k -> event_ch[k]!(true)) ];

            c.pop?result;
            assert(result = expected, "event ", i, ": want ", expected, ", got ", result);
            log("event ", i, ": pushed ", pushed, ", got ", result, " (correct)");

            delay := 0;
            *[ delay < 300 -> delay := delay + 1 ];

            i := i + 1
        ];

        log("======== 16-event generality test complete ========")
    }
}

e2e_multi_event_test emt;
