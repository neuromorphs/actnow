import "chips/bench/core.act";
import "gen/file_ids.act";

// End-to-end test for core/soc.act's reset_ext, using a real compiled
// program through the real bootloader -- complements
// tests/core/reset_test.act, which proves the same mechanism with
// hand-assembled instructions and checks hang recovery/vector-clearing in
// detail.
//
// Sequence: boot, run one batch through the program's real ISR (same as
// e2e_fifo_test.act's batch 1), fire external reset, then run a second
// batch. Reset clears the interrupt controller's vector table and enable
// mask but leaves internal RAM untouched, so the same bootloader+
// application image re-runs from scratch: the bootloader re-copies
// application into SRAM, which re-registers its ISR vector, re-configures
// fifo_in's trigger level, and re-enables event_id_0. If any of that didn't
// genuinely reset and reconfigure, the second batch would hang or misbehave.
defproc e2e_reset_test() {
    core<ROM_IMAGE> c;
    c.event_id_0 = c.fifo_event;

    int<WIDTH_DATA> result;
    int<32> delay;

    chp {
        log("======== reset e2e test start ========");

        // soc no longer boots itself -- assert reset_ext once to kick it off
        // (distinct from the mid-test reset_ext below, which proves recovery
        // rather than boot).
        c.reset_ext!true;

        // --- Batch 1: identical to e2e_fifo_test.act's own batch 1 --
        // push 41, 42, 43, ISR computes +1 on each, expect 42, 43, 44 out.
        log("--- batch 1: pushing 41, 42, 43 into the input FIFO ---");
        c.push!int(41, WIDTH_DATA);
        c.push!int(42, WIDTH_DATA);
        c.push!int(43, WIDTH_DATA);

        c.pop?result;
        assert(result = 42, "batch 1 result 1: want 42, got ", result);
        c.pop?result;
        assert(result = 43, "batch 1 result 2: want 43, got ", result);
        c.pop?result;
        assert(result = 44, "batch 1 result 3: want 44, got ", result);
        log("batch 1: got 42, 43, 44 back from the output FIFO");

        delay := 0;
        *[ delay < 3000 -> delay := delay + 1 ];

        log("--- asserting external reset ---");
        c.reset_ext!true;
        log("--- reset done -- bootloader + application should now be rebooting from scratch ---");

        // --- Batch 2: push 41, 42, 43 again. Only passes if the rebooted
        // application genuinely re-registered its ISR vector, trigger
        // level, and enable bit from a clean interrupt controller -- this
        // push just blocks until the rebooted program is ready.
        log("--- batch 2 (post-reset): pushing 41, 42, 43 into the input FIFO ---");
        c.push!int(41, WIDTH_DATA);
        c.push!int(42, WIDTH_DATA);
        c.push!int(43, WIDTH_DATA);

        c.pop?result;
        assert(result = 42, "batch 2 result 1: want 42, got ", result);
        c.pop?result;
        assert(result = 43, "batch 2 result 2: want 43, got ", result);
        c.pop?result;
        assert(result = 44, "batch 2 result 3: want 44, got ", result);
        log("batch 2: got 42, 43, 44 back from the output FIFO -- real reboot after reset confirmed");

        log("======== reset e2e test complete ========")
    }
}

e2e_reset_test ert;
